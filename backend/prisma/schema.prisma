generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  patient
  doctor
  admin
  clerk
}

enum AppointmentStatus {
  requested
  confirmed
  completed
  cancelled
}

enum FacilityType {
  hospital
  clinic
}

enum ObservationStatus {
  registered
  preliminary
  final
  amended
  cancelled
}

enum MedicationRequestStatus {
  active
  on_hold
  cancelled
  completed
  stopped
  draft
  unknown
}

model Facility {
  id          String       @id @default(cuid())
  name        String
  type        FacilityType
  parentId    String?
  parent      Facility?    @relation("FacilityHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Facility[]   @relation("FacilityHierarchy")
  address     String?
  phone       String?
  notes       String?
  createdAt   DateTime     @default(now())

  appointments  Appointment[]
  records       MedicalRecord[]
  primaryDoctors DoctorProfile[] @relation("DoctorPrimaryFacility")

  @@index([parentId])
  @@index([type])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  createdAt    DateTime @default(now())

  doctorProfile     DoctorProfile?
  patientProfile    PatientProfile?
  patientAppointments  Appointment[]   @relation("PatientAppointments")
  doctorAppointments   Appointment[]   @relation("DoctorAppointments")
  authoredRecords      MedicalRecord[] @relation("AuthoredRecords")
  patientRecords       MedicalRecord[] @relation("PatientRecords")
  uploadedFiles        MedicalFile[]   @relation("UploadedFiles")
  patientFiles         MedicalFile[]   @relation("PatientFiles")

  patientObservations    Observation[]        @relation("PatientObservations")
  performedObservations  Observation[]        @relation("PerformerObservations")
  patientMedReqs         MedicationRequest[]  @relation("PatientMedicationRequests")
  prescriberMedReqs      MedicationRequest[]  @relation("PrescriberMedicationRequests")

  patientAuditLogs       PatientAuditLog[]    @relation("PatientAuditLogs")
  actorAuditLogs         PatientAuditLog[]    @relation("ActorAuditLogs")
}

model PatientProfile {
  userId           String  @id
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth      DateTime?
  phone            String?
  address          String?
  bloodType        String?
  allergies        String?
  emergencyContact String?
}

model DoctorProfile {
  userId          String  @id
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty       String
  licenseNumber   String  @unique
  yearsExperience Int?
  bio             String?
  primaryFacilityId String?
  primaryFacility   Facility? @relation("DoctorPrimaryFacility", fields: [primaryFacilityId], references: [id], onDelete: SetNull)
  availabilitySlots AvailabilitySlot[]

  @@index([primaryFacilityId])
}

model AvailabilitySlot {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [userId], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())

  @@index([doctorId, startsAt])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  patient         User              @relation("PatientAppointments", fields: [patientId], references: [id])
  doctorId        String
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  reason          String
  status          AppointmentStatus @default(requested)
  notes           String?
  facilityId      String?
  facility        Facility?         @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([facilityId])
}

model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  patient     User     @relation("PatientRecords", fields: [patientId], references: [id])
  authorId    String
  author      User     @relation("AuthoredRecords", fields: [authorId], references: [id])
  title       String
  description String
  diagnosis   String?
  treatment   String?
  facilityId  String?
  facility    Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([facilityId])
}

model MedicalFile {
  id         String   @id @default(cuid())
  patientId  String
  patient    User     @relation("PatientFiles", fields: [patientId], references: [id])
  uploaderId String
  uploader   User     @relation("UploadedFiles", fields: [uploaderId], references: [id])
  fileName   String
  fileType   String
  fileSize   Int
  url        String
  uploadedAt DateTime @default(now())

  @@index([patientId])
}

// ============================================================
// FHIR R4 interoperability
// ============================================================

model ApiClient {
  id          String       @id @default(cuid())
  name        String
  // Store only the SHA-256 hash of the API key — never the plaintext.
  keyHash     String       @unique
  keyPrefix   String       // first 8 chars of the key, for display
  // Space-separated SMART-style scopes, e.g. "patient.read observation.write"
  scopes      String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime?

  events      ApiClientEvent[]

  @@index([active])
}

model ApiClientEvent {
  id          String    @id @default(cuid())
  clientId    String
  client      ApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  method      String
  path        String
  status      Int
  resource    String?
  createdAt   DateTime  @default(now())

  @@index([clientId, createdAt])
}

model Observation {
  id            String            @id @default(cuid())
  patientId     String
  patient       User              @relation("PatientObservations", fields: [patientId], references: [id], onDelete: Cascade)
  performerId   String?
  performer     User?             @relation("PerformerObservations", fields: [performerId], references: [id], onDelete: SetNull)
  status        ObservationStatus @default(final)
  // LOINC code identifying the observation/lab test
  code          String
  display       String
  // Numeric or string value
  valueNumber   Float?
  valueString   String?
  unit          String?
  // For panels (e.g. CBC), category like "laboratory" | "vital-signs"
  category      String?
  effectiveAt   DateTime
  note          String?
  // Optional source reference (e.g. external system message id)
  sourceSystem  String?
  sourceId      String?
  createdAt     DateTime          @default(now())

  @@index([patientId, effectiveAt])
  @@index([code])
  @@unique([sourceSystem, sourceId])
}

model MedicationRequest {
  id            String                  @id @default(cuid())
  patientId     String
  patient       User                    @relation("PatientMedicationRequests", fields: [patientId], references: [id], onDelete: Cascade)
  prescriberId  String?
  prescriber    User?                   @relation("PrescriberMedicationRequests", fields: [prescriberId], references: [id], onDelete: SetNull)
  status        MedicationRequestStatus @default(active)
  // RxNorm code or free text
  medicationCode String?
  medicationName String
  dosage         String?
  // e.g. "BID", "QD", "PRN"
  frequency      String?
  authoredOn     DateTime                @default(now())
  note           String?
  sourceSystem   String?
  sourceId       String?
  createdAt      DateTime                @default(now())

  @@index([patientId, authoredOn])
  @@unique([sourceSystem, sourceId])
}

// ============================================================
// Audit log — clerk/admin/doctor changes to patient profiles
// ============================================================

enum PatientAuditAction {
  created
  updated
}

model PatientAuditLog {
  id         String              @id @default(cuid())
  patientId  String
  patient    User                @relation("PatientAuditLogs", fields: [patientId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User                @relation("ActorAuditLogs", fields: [actorId], references: [id])
  // Snapshot of actor identity at time of write — survives if the actor is later deleted.
  actorName  String
  actorRole  UserRole
  action     PatientAuditAction
  // JSON-encoded array of { field, before, after } entries
  changes    String
  createdAt  DateTime            @default(now())

  @@index([patientId, createdAt])
}
