# PostgreSQL connection string
DATABASE_URL="postgresql://caretide:caretide@localhost:5432/caretide?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=8080
CORS_ORIGIN="http://localhost:5173,http://localhost:8080"

# File uploads (local disk path)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=25
