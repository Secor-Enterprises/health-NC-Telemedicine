{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Secor HealthConnect Design Tokens",
  "version": "1.0.0",
  "status": "candidate",
  "sources": [
    "src/app/globals.css",
    "Figma file 3qDF55zDbiYe95zfNRjQuE",
    "docs/programme/ARCHITECTURE_SECURITY_DATA_BASELINE.md"
  ],
  "principles": [
    "Clinical clarity before decoration",
    "Accessible without colour dependence",
    "Usable under constrained connectivity",
    "Synthetic demonstration data only",
    "Integration states must disclose live, sandbox, mocked, unavailable or disabled status"
  ],
  "breakpoints": {
    "mobile": { "min": 320, "max": 699, "reference": 390 },
    "tablet": { "min": 700, "max": 979, "reference": 834 },
    "desktop": { "min": 980, "max": 1439, "reference": 1280 },
    "wide": { "min": 1440, "reference": 1440 }
  },
  "color": {
    "primitive": {
      "navy-900": "#09263F",
      "navy-800": "#12344F",
      "navy-700": "#173B57",
      "ink-900": "#112436",
      "slate-600": "#6D7E8C",
      "slate-300": "#A9C3D4",
      "line-200": "#DBE5EB",
      "surface-050": "#F4F8FA",
      "white": "#FFFFFF",
      "cyan-500": "#00A6D6",
      "teal-600": "#008F86",
      "teal-050": "#DFF6F2",
      "green-600": "#2D8A52",
      "green-400": "#52D38F",
      "green-050": "#E9F7EF",
      "amber-500": "#E3A313",
      "amber-700": "#9A6900",
      "amber-050": "#FFF5DA",
      "red-600": "#C94747",
      "red-050": "#FDEAEA",
      "blue-050": "#EAF5FA",
      "blue-600": "#19759B"
    },
    "semantic": {
      "background/page": "{color.primitive.surface-050}",
      "background/surface": "{color.primitive.white}",
      "background/navigation": "{color.primitive.navy-900}",
      "background/navigation-hover": "{color.primitive.navy-700}",
      "background/accent": "{color.primitive.teal-600}",
      "text/primary": "{color.primitive.ink-900}",
      "text/secondary": "{color.primitive.slate-600}",
      "text/inverse": "{color.primitive.white}",
      "text/navigation-muted": "{color.primitive.slate-300}",
      "border/default": "{color.primitive.line-200}",
      "focus/ring": "{color.primitive.cyan-500}",
      "status/success": "{color.primitive.green-600}",
      "status/success-bg": "{color.primitive.green-050}",
      "status/warning": "{color.primitive.amber-700}",
      "status/warning-bg": "{color.primitive.amber-050}",
      "status/danger": "{color.primitive.red-600}",
      "status/danger-bg": "{color.primitive.red-050}",
      "status/information": "{color.primitive.blue-600}",
      "status/information-bg": "{color.primitive.blue-050}"
    }
  },
  "typography": {
    "font-family/design": "Inter",
    "font-family/code": "Inter, Segoe UI, Arial, Helvetica, sans-serif",
    "weight/regular": 400,
    "weight/medium": 500,
    "weight/semibold": 600,
    "weight/bold": 700,
    "weight/extrabold": 800,
    "size/label-sm": 11,
    "size/body-sm": 12,
    "size/body-md": 14,
    "size/body-lg": 16,
    "size/title-sm": 20,
    "size/title-md": 28,
    "size/title-lg": 34,
    "line-height/tight": 1.2,
    "line-height/default": 1.5,
    "line-height/relaxed": 1.65,
    "letter-spacing/eyebrow": "0.12em",
    "letter-spacing/title": "-0.03em"
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "7": 28,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radius": {
    "none": 0,
    "sm": 8,
    "md": 10,
    "lg": 12,
    "xl": 14,
    "2xl": 17,
    "round": 999
  },
  "border": {
    "width/default": 1,
    "width/strong": 2,
    "width/accent": 6
  },
  "elevation": {
    "surface": "0 8px 28px rgba(23, 57, 78, 0.04)",
    "floating": "0 12px 30px rgba(0, 26, 43, 0.27)",
    "focus": "0 0 0 3px rgba(0, 166, 214, 0.35)"
  },
  "motion": {
    "duration/fast": 120,
    "duration/default": 200,
    "duration/slow": 320,
    "easing/standard": "cubic-bezier(0.2, 0, 0, 1)",
    "easing/exit": "cubic-bezier(0.4, 0, 1, 1)",
    "reduced-motion": "Remove non-essential movement and replace animated progress with text/status updates"
  },
  "touch": {
    "minimum-target": 44,
    "preferred-target": 48
  },
  "content-width": {
    "sidebar/desktop": 252,
    "sidebar/tablet": 84,
    "search/max": 520,
    "form/comfortable": 640,
    "reading/max": 720
  }
}
